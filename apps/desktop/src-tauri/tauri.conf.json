{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "taurimozaic",
  "version": "0.1.0",
  "identifier": "com.noumi0k.taurimozaic",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "taurimozaic",
        "width": 1360,
        "height": 880,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [
      "resources/review-runtime"
    ]
  }
}
